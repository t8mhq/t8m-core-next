#!/usr/bin/env bash
# S1-G0 · D5 — Provision Postgres roles and databases for the Core.
#
#   app_migrator — schema owner; runs migrations (LOGIN CREATEDB).
#   app_user     — runtime + test-suite connection; NOSUPERUSER NOBYPASSRLS.
#                  G1's RLS suite relies on app_user not bypassing RLS.
#
# Idempotent. Run as a Postgres superuser (local dev: your OS role; CI: postgres).
# Provisions the development + test databases by default; pass DB names to override.
#
#   bin/provision-db                              # dev + test
#   bin/provision-db core_next_test               # just test (CI)
#
# Auth defaults (override via env):
#   PGHOST=localhost PGPORT=5432 PGADMIN_USER=$(whoami) PGADMIN_DB=postgres
#   APP_MIGRATOR_PASSWORD=app_migrator APP_USER_PASSWORD=app_user
set -euo pipefail

PGHOST="${PGHOST:-localhost}"
PGPORT="${PGPORT:-5432}"
ADMIN_USER="${PGADMIN_USER:-$(whoami)}"
ADMIN_DB="${PGADMIN_DB:-postgres}"
MIGRATOR_PASSWORD="${APP_MIGRATOR_PASSWORD:-app_migrator}"
USER_PASSWORD="${APP_USER_PASSWORD:-app_user}"

here="$(cd "$(dirname "$0")" && pwd)"

if [ "$#" -gt 0 ]; then
  DATABASES=("$@")
else
  DATABASES=(core_next_development core_next_test)
fi

admin() { psql -v ON_ERROR_STOP=1 -h "$PGHOST" -p "$PGPORT" -U "$ADMIN_USER" -d "$1" "${@:2}"; }

echo "==> Provisioning roles (admin=${ADMIN_USER}@${PGHOST}:${PGPORT})"
admin "$ADMIN_DB" \
  -v migrator_password="$MIGRATOR_PASSWORD" \
  -v user_password="$USER_PASSWORD" \
  -f "${here}/../db/roles.sql"

for db in "${DATABASES[@]}"; do
  echo "==> Provisioning database ${db} (owner=app_migrator)"
  if ! admin "$ADMIN_DB" -tAc "SELECT 1 FROM pg_database WHERE datname = '${db}'" | grep -q 1; then
    admin "$ADMIN_DB" -c "CREATE DATABASE \"${db}\" OWNER app_migrator"
  fi
  admin "$db" <<SQL
GRANT CONNECT ON DATABASE "${db}" TO app_user;
GRANT USAGE ON SCHEMA public TO app_user;
-- Objects created later by app_migrator become usable by app_user automatically.
ALTER DEFAULT PRIVILEGES FOR ROLE app_migrator IN SCHEMA public
  GRANT SELECT, INSERT, UPDATE, DELETE ON TABLES TO app_user;
ALTER DEFAULT PRIVILEGES FOR ROLE app_migrator IN SCHEMA public
  GRANT USAGE, SELECT ON SEQUENCES TO app_user;
-- Backfill for anything already present.
GRANT SELECT, INSERT, UPDATE, DELETE ON ALL TABLES IN SCHEMA public TO app_user;
GRANT USAGE, SELECT ON ALL SEQUENCES IN SCHEMA public TO app_user;
SQL
done

echo "==> Done. Roles: app_migrator (owner) · app_user (runtime, NOSUPERUSER NOBYPASSRLS)"
